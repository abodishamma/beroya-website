# Hosted card checkout URL from Stripe / PayTabs / Tap / another certified gateway.
# For dynamic production payments, connect this to a backend-created checkout session URL.
VITE_CARD_PAYMENT_URL=

# Supabase Auth is required for real customer accounts and email verification.
# Create a Supabase project, enable Email OTP / magic links, then add these values.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
